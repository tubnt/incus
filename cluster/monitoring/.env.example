# Alertmanager SMTP 配置
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=alertmanager@example.com
SMTP_USERNAME=alertmanager@example.com
SMTP_PASSWORD=<请使用 openssl rand -base64 24 生成强密码>

# 告警通知目标
ALERT_EMAIL_TO=ops@example.com
ALERT_WEBHOOK_URL=https://example.com/webhook/alert
ALERT_WEBHOOK_TOKEN=<请使用 openssl rand -base64 32 生成随机令牌>

# Grafana 管理员密码（必填，不可为空）
GRAFANA_ADMIN_PASSWORD=<请使用 openssl rand -base64 24 生成强密码>

# Loki 认证说明：当前为单节点模式，auth_enabled=false
# 多租户场景需启用认证，参见 loki/loki-config.yml
